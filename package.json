{
  "name": "ticket-dashboard-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "install:all": "npm install --prefix server && npm install --legacy-peer-deps --prefix client",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "test:server": "npm run test --prefix server"
  }
}
